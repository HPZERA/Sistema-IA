# Postgres connection string (e.g. provided by the Vercel Postgres/Neon integration, or any
# other Postgres provider — Supabase, Neon directly, self-hosted). Required for everything
# under src/db/ and src/lib/ai-providers/store.ts, src/lib/generations.ts, src/lib/favorites.ts,
# src/lib/templates.ts.
DATABASE_URL=

# Vercel Blob read/write token. Required by src/lib/blob.ts (upload/replace/delete of Character
# Library images) — the @vercel/blob SDK reads this env var implicitly, it's never referenced
# directly in code. When the project has a Vercel Blob store attached, this is injected
# automatically in Preview/Production; for local development, create a store at
# https://vercel.com/dashboard/stores, copy its token, and set it here. Without it, character
# image upload/replace/delete requests fail — the rest of the app is unaffected.
BLOB_READ_WRITE_TOKEN=
